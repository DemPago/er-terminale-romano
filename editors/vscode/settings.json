// =============================================================================
// Er Terminale Romano — VS Code User Settings
//
// ISTRUZIONI:
// Apri VS Code → Cmd+Shift+P (Mac) / Ctrl+Shift+P (Linux)
// → "Open User Settings (JSON)" → aggiungi le chiavi qui sotto.
//
// PERCORSO MANUALE:
//   macOS  →  ~/Library/Application Support/Code/User/settings.json
//   Linux  →  ~/.config/Code/User/settings.json
//
// NON sovrascrivere l'intero file se hai già impostazioni — aggiungi
// solo le chiavi mancanti, oppure usa install.sh per un merge sicuro.
// =============================================================================
{
  // ---------------------------------------------------------------------------
  // OpenCode — modello e istruzioni globali
  // La configurazione a livello di progetto (opencode.json) ha la precedenza.
  // ---------------------------------------------------------------------------
  "opencode.model": "ollama/romano",
  "opencode.instructions": "Rispondi sempre in dialetto romanesco verace come un programmatore senior romano. Vai dritto al punto, usa espressioni tipiche romane ma mantieni sempre la precisione tecnica. Non fa' er coatto: codice pulito e risposte dirette.",

  // ---------------------------------------------------------------------------
  // Terminale integrato — shell raccomandata per OpenCode
  // ---------------------------------------------------------------------------
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.linux": "bash",

  // ---------------------------------------------------------------------------
  // Associazioni file del progetto er-terminale-romano
  // ---------------------------------------------------------------------------
  "files.associations": {
    "Modelfile": "plaintext",
    "spinners.json": "json"
  },

  // ---------------------------------------------------------------------------
  // Esclude cartelle inutili dal file explorer
  // ---------------------------------------------------------------------------
  "files.exclude": {
    "**/*.backup.*": true
  }
}
